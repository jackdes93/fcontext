# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_TTL=24h

# PostgreSQL Configuration
POSTGRES_DSN=postgres://mqtt_user:mqtt_pass@localhost:5432/mqtt_db?sslmode=disable

# Application
APP_ENV=dev
HTTP_PORT=8080
